{
  "expo": {
    "name": "Yummi",
    "slug": "Yummi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/img/logo.png", // <-- CORREGIDO (era /images/)
    "scheme": "Yummi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/img/logo.png", // <-- CORREGIDO (era la ruta que daba error)
        // Borré las otras imágenes (background, monochrome) que también iban a fallar.
        // Con el logo y el color de fondo es suficiente.
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.alexsklx.Yummi"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/img/logo.png" // <-- CORREGIDO (era /images/)
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/img/logo.png", // <-- Esta ya estaba bien
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a1d3d469-8f61-4fcd-9567-8f3b70fe0c3c"
      }
    }
  }
}